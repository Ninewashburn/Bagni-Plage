# Root Git ignore for Bagni Plage

# Java / Maven
backend/target/
backend/.classpath
backend/.project
backend/.settings/
backend/*.iml
backend/*.log
backend/log/
backend/*.db

# Node / Angular
frontend/node_modules/
frontend/dist/
frontend/out-tsc/
frontend/.angular/
frontend/*.log
frontend/coverage/
frontend/.nyc_output/

# IDEs
.vscode/
.idea/
*.iml

# OS
.DS_Store
Thumbs.db

# Environment and secrets
*.env
.env.*

# Generated files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
pnpm-lock.yaml

# Business case files to exclude
businesscase.pdf
CLAUDE.md
